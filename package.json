{
  "name": "openseries-ts",
  "version": "1.0.0",
  "type": "module",
  "description": "Tools for analyzing financial timeseries. TypeScript port of the Python openseries package.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "report": "tsx scripts/report.ts",
    "report:iris": "tsx scripts/report.ts --iris",
    "report:captor": "tsx scripts/report.ts",
    "docs": "node -e \"require('fs').rmSync('docs',{recursive:true,force:true})\" && typedoc && node -e \"require('fs').writeFileSync('docs/.nojekyll','')\""
  },
  "keywords": [
    "finance",
    "fintech",
    "timeseries",
    "investment",
    "risk",
    "volatility",
    "portfolio"
  ],
  "author": "",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.3",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "date-holidays": "^3.26.8",
    "open": "^11.0.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  }
}
